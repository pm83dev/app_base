<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <SpaRoot>..\..\frontend\</SpaRoot>
    <SpaProxyServerUrl>http://localhost:4200</SpaProxyServerUrl>
    <SpaProxyLaunchCommand>npm start</SpaProxyLaunchCommand>
    <SpaProxyWorkingDirectory>$(SpaRoot)</SpaProxyWorkingDirectory>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.5" />
    <PackageReference Include="Microsoft.AspNetCore.SpaProxy" Version="10.0.5" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../backend.factory/backend.factory.csproj" />
    <ProjectReference Include="../backend.repository/backend.repository.csproj" />
  </ItemGroup>


  <Target Name="BuildFrontendForPublish" BeforeTargets="Publish">
    <Exec WorkingDirectory="..\..\frontend" Command="npm install" />
    <Exec WorkingDirectory="..\..\frontend" Command="npm run build -- --configuration production" />
  </Target>

</Project>